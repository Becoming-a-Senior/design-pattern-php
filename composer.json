{
    "name": "becoming-a-senior/design-pattern-php",
    "description": "A collection of PHP design pattern implementations and SOLID principles, with practical before/after examples and clear explanations.",
    "license": "MIT",
    "authors": [
        {
            "name": "BecomingASenior.com",
            "email": "moe@meetmoe.de"
        }
    ],
    "minimum-stability": "stable",
    "scripts": {
        "lint": "phpcs .",
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "tools": [
            "@lint",
            "@test",
            "@analyse"
        ]
    },
    "autoload": {
        "psr-4": {
            "DesignPattern\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.4",
        "ext-simplexml": "*",
        "ext-json": "*",
        "ext-libxml": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "squizlabs/php_codesniffer": "^4.0",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-phpunit": "^2.0"
    }
}
